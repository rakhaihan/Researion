# Application
ENVIRONMENT=development
APP_NAME=Researion
APP_VERSION=1.0.0
DEBUG=true
LOG_JSON=false
API_PREFIX=/api
AUTO_CREATE_TABLES=false
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/researion

# Redis (background job queue)
REDIS_URL=redis://redis:6379/0

# Authentication
AUTH_MODE=jwt
SECRET_KEY=change-me-use-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY=

# Dev user (AUTH_MODE=disabled or api_key fallback)
DEV_USER_EMAIL=dev@researion.local
DEV_USER_PASSWORD=devpassword123
DEV_USER_FULL_NAME=Development User

# LLM
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2

# Search
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
SERPAPI_API_KEY=
ALLOW_SEARCH_FALLBACK=true

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security
MAX_REQUEST_BODY_BYTES=1048576
AUTH_RATE_LIMIT=10/minute
ADMIN_API_KEY=
GUNICORN_WORKERS=2

# Research settings
MAX_SEARCH_RESULTS=5
MIN_CREDIBILITY_SCORE=5.0

# Knowledge Base (Phase 7)
DOCUMENT_STORAGE_DIR=storage/documents
MAX_DOCUMENT_SIZE_MB=10
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=150
EMBEDDING_PROVIDER=mock
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE=memory
RAG_TOP_K=5
