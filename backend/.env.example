# Application
APP_NAME=Researion
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/researion

# Redis (background job queue)
REDIS_URL=redis://redis:6379/0

# LLM
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2

# Search
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
SERPAPI_API_KEY=
ALLOW_SEARCH_FALLBACK=true

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Research settings
MAX_SEARCH_RESULTS=5
MIN_CREDIBILITY_SCORE=5.0
