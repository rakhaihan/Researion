# Production environment — copy to .env.production and set real secrets.
ENVIRONMENT=production
DEBUG=false
LOG_JSON=true

APP_NAME=Researion
API_PREFIX=/api
AUTO_CREATE_TABLES=false

DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_DB_PASSWORD@db:5432/researion
REDIS_URL=redis://redis:6379/0

AUTH_MODE=jwt
SECRET_KEY=REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=https://app.example.com
BACKEND_CORS_ORIGINS=https://app.example.com

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-your-production-key
TAVILY_MAX_RESULTS=5
ALLOW_SEARCH_FALLBACK=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

MAX_REQUEST_BODY_BYTES=1048576
AUTH_RATE_LIMIT=10/minute
GUNICORN_WORKERS=2

# Optional admin maintenance (POST /api/jobs/admin/cleanup with X-Admin-Key header)
ADMIN_API_KEY=
